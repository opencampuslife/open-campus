# ──────────────────────────────────────────────
# Gaokao Agent — Production Configuration
# ──────────────────────────────────────────────
# Copy to .env and fill in secrets before deploying.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Environment ──────────────────────────────
APP_ENV=production
ENVIRONMENT=prod
GAOKAO_ENV=production
RELEASE_CHECK_STRICT=true
BENCHMARK_ADMISSIONS_BLOCKING=false
BENCHMARK_ADMISSIONS_THRESHOLD=85
BENCHMARK_MEALBOT_BLOCKING=true
BENCHMARK_MEALBOT_THRESHOLD=90
ALLOW_DEV_IDENTITY_OVERRIDE=0

# ── Identity / Auth ──────────────────────────
# IMPORTANT: In production, x-gaokao-* headers MUST be injected by a
# trusted upstream proxy/auth layer (e.g. API Gateway, OIDC middleware,
# internal BFF session middleware). The edge MUST strip external
# x-gaokao-* headers — only internal auth middleware may inject them.
# See docs/TRUSTED_PROXY_BOUNDARY.md for deployment guide.
#   Nginx example:
#     proxy_set_header X-Gaokao-User-Id "";
#     proxy_set_header X-Gaokao-Role "";
#     proxy_set_header X-Gaokao-Campus "";
#     (then re-inject after authentication)
# ─────────────────────────────────────────────

# ── DeepSeek LLM ─────────────────────────────
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_ENABLE_LLM=0

# -- WeCom AI Bot WebSocket Bridge ----------------
# Create an API-mode smart bot in WeCom and choose the long-connection mode.
# WECOM_AIBOT_BOT_ID=aib_xxx
# WECOM_AIBOT_SECRET=<bot-secret>
# WECOM_AIBOT_API_URL=http://127.0.0.1:8787/api/gaokao/chat
# WECOM_AIBOT_CAMPUS=all
# WECOM_AIBOT_TRUSTED_PROXY_TOKEN=<same-as-TRUSTED_PROXY_TOKEN>
# WECOM_AIBOT_WS_URL=wss://openws.work.weixin.qq.com

# -- WeCom campus callback / media intake ----------------
# WECOM_CORP_ID=ww_xxx
# WECOM_AGENT_ID=1000001
# WECOM_SECRET=<app-secret>
# WECOM_APP_SECRET=<app-secret>
# WECOM_TRANSPORT_MODE=stub
# WECOM_TOKEN=<callback-token>
# WECOM_ENCODING_AES_KEY=<43-char-encoding-aes-key>
# WECOM_SCHOOL_ID=school_demo
# WECOM_H5_OAUTH_AUTO_REDIRECT=1

# ── PostgreSQL ───────────────────────────────
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:54329/gaokao_agent_test
DATABASE_URL_PUBLIC=postgresql://gaokao_api_public:postgres@localhost:54329/gaokao_agent_test
DATABASE_URL_STAFF=postgresql://gaokao_api_staff:postgres@localhost:54329/gaokao_agent_test
DATABASE_URL_ADMIN_APP=postgresql://gaokao_api_admin:postgres@localhost:54329/gaokao_agent_test

# ── Security ─────────────────────────────────
CSRF_TOKEN_SECRET=<generate-with: python3 -c "import secrets; print(secrets.token_hex(32))">
CSRF_TOKEN_TTL_SECONDS=3600

CHAT_RATE_LIMIT_PER_MINUTE=30
ADMIN_RATE_LIMIT_PER_MINUTE=60

ENABLE_REMOTE_URL_INGESTION=0

# ── RAG Source ───────────────────────────────
# RAG_SOURCE=postgres

# ── Server ───────────────────────────────────
# HOST=0.0.0.0
# PORT=8787
APP_BASE_URL=https://school.example.com
# H5_API_BASE_URL=  # Keep empty for same-origin session cookie requests.
UPLOAD_DIR=/var/lib/gaokao-agent/uploads
REMINDER_WORKER_INTERVAL_SECONDS=5
MEDIA_WORKER_INTERVAL_SECONDS=5
