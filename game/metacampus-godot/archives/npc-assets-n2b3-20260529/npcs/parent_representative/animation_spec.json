{
  "version": "1.0",
  "date": "2026-05-29",
  "author": "Narrative Designer",
  "npc_id": "parent_representative",
  "display_name": "顾兰",
  "role": "家长代表",
  "location": "school_main_hall",

  "frame_size": {
    "width": 64,
    "height": 64,
    "note": "单帧尺寸（含4px底部阴影空间）"
  },

  "frame_count": {
    "per_direction": 4,
    "note": "walk cycle：接触帧→过渡帧→交叉帧→过渡帧（150ms/帧≈6.67fps）"
  },

  "directions": 4,
  "note": "上下左右四方向，每个方向独立walk sheet文件",

  "anchor_point": {
    "x": 32,
    "y": 60,
    "note": "锚点在脚底中心偏下"
  },

  "transparent_padding": {
    "top": 4,
    "left": 8,
    "right": 8,
    "bottom": 4,
    "note": "头顶留4px，左右各8px，底部已含4px阴影"
  },

  "animations": {
    "idle": {
      "type": "static",
      "frames": [0],
      "frame_rate": 0,
      "note": "idle使用sprite_idle.png"
    },
    "walk": {
      "type": "loop",
      "frames": [0, 1, 2, 3],
      "frame_rate": 150,
      "note": "walk sheet每帧间隔150ms"
    }
  },

  "walk_sheet_layout": {
    "sheet_dimensions": {
      "width": 256,
      "height": 64
    },
    "grid": "1 row × 4 columns",
    "frame_order": [
      "frame_0_contact",
      "frame_1_transition",
      "frame_2_cross",
      "frame_3_transition"
    ]
  },

  "naming_convention": {
    "idle_sprite": "baseline/sprite_idle.png",
    "walk_sheet": "baseline/parent_representative_walk_{direction}.png",
    "directions": ["down", "up", "left", "right"]
  },

  "style_constraints": {
    "proportions": {
      "total_height": 64,
      "head_ratio": "1/4",
      "head_px": 16,
      "torso_px": 20,
      "legs_px": 28
    },
    "outline": "1px 深色描边 #1A1A2E",
    "shadow": "4px底部椭圆阴影 20%透明度",
    "colors": {
      "primary": "#2D4A6B",
      "accent": "#F5E6D3",
      "briefcase": "#374151",
      "skin": "#F4C7A1",
      "outline": "#1A1A2E"
    },
    "max_color_count": 5,
    "texture_filter": "Nearest"
  },

  "character_description": {
    "age": "约40-50岁",
    "body_type": "站姿挺拔",
    "clothing": "深蓝休闲西装外套（#2D4A6B）+ 暖白内搭（#F5E6D3）",
    "accessories": "深灰色公文包（#374151）",
    "skin": "#F4C7A1",
    "note": "家长代表角色，需体现专业可信赖感"
  },

  "godot_integration": {
    "import_mode": "2D",
    "texture_filter": "Nearest",
    "hframes": 4,
    "vframes": 1
  }
}